# 🔧 CONFIGURACIÓN TODASLASCASAS.MX
# Copiar a .env y rellenar con valores reales

# 🗄️ BASE DE DATOS POSTGRESQL
DB_HOST=tu-host-postgres.com
DB_NAME=nombre_base_datos
DB_USER=usuario_postgres
DB_PASSWORD=tu_password_seguro
DB_PORT=5432

# ☁️ AWS LAMBDA
LAMBDA_URL=https://tu-api-gateway.amazonaws.com/prod
AWS_REGION=us-east-1

# 📦 AWS S3
S3_BUCKET=todaslascasas-imagenes
S3_REGION=us-east-1

# 🔐 CLAVES API (si necesario)
API_KEY=tu_api_key_si_necesario
SECRET_KEY=tu_secret_key
